# Örnek ortam değişkenleri — gerçek değerleri .env.local dosyasına yazın.
# (.env.local git'e girmez; bu dosya sadece hangi ayarların var olduğunu belgeler.)

# Admin paneli şifresi (http://localhost:3000/admin) — boşsa panel kapalı kalır.
ADMIN_PASSWORD=

# AI sağlayıcı seçimi: "mock" (anahtarsız, sahte kapak) | "fal" (gerçek üretim).
# Boş bırakılırsa: FAL_KEY varsa fal, yoksa mock kullanılır.
AI_PROVIDER=

# fal.ai API anahtarı (gerçek AI görsel üretimi için — src/lib/ai/fal.ts'e bak)
FAL_KEY=

# Ücretsiz önizleme limitleri (istismar koruması)
# IP başına günlük hak (varsayılan 5) ve tüm site için günlük tavan (varsayılan 100)
TEASER_IP_LIMIT=
TEASER_DAILY_LIMIT=
